<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Posting the alert notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Resolve a friendly label/icon for the app that triggered Play Integrity. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".AlertApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PlayIntegrityAlert">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Lets LSPosed open this screen from the module list. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="de.robv.android.xposed.category.MODULE_SETTINGS" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AppPickerActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Receives detection events from the hook (in the Play Store process) and
             raises the alert from our own app, with our icon and notification channel. -->
        <receiver
            android:name=".DetectionReceiver"
            android:exported="true"
            tools:ignore="ExportedReceiver" />

        <!-- Xposed / LSPosed module metadata (libxposed API v102+ / LSPosed era). -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="@string/xposed_description" />
        <meta-data
            android:name="xposedminversion"
            android:value="102" />
        <!-- Suggested scope: Play Store (hosts the integrity service) + this app. -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />
    </application>
</manifest>
