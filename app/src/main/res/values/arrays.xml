<resources>
    <!-- Scope LSPosed suggests when you open the module's scope screen: just the
         Play Store process, which hosts the integrity service. We deliberately do
         NOT list this app — LSPosed won't let you tick your own module, and it
         auto-scopes a legacy module to itself anyway (that's what flips the
         in-app "module loaded" status). LSPosed only *suggests* this scope; you
         still have to tick Google Play Store yourself. -->
    <string-array name="xposed_scope">
        <item>com.android.vending</item>
    </string-array>
</resources>
