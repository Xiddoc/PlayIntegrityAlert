<resources>
    <style name="Theme.PlayIntegrityAlert" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryDark">@color/brand_dark</item>
        <item name="colorOnPrimary">@color/brand_dark</item>
        <item name="android:windowBackground">@drawable/bg_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Frosted-glass card: translucent fill, hairline stroke, generous radius. -->
    <style name="Widget.PIA.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/glass_fill</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">20dp</item>
    </style>
</resources>
